    {
      "name": "Login - Sucesso",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status deve ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar token\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.token).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"dani@teste.com\",\r\n  \"senha\": \"123456\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/auth/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
