    {
      "name": "Register - Sucesso",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let email = \"dani\" + Date.now() + \"@teste.com\";\r",
              "pm.environment.set(\"email\", email);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status deve ser 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar email\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.email).to.exist;\r",
              "});"
            ],
